# Hospital Management System - Git Ignore File
# This file prevents sensitive and unnecessary files from being committed

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Configuration (with sensitive data)
config.ini
.env
.env.local
.env.*.local

# Database backups
backups/
*.sql.bak
*.dump
*.backup

# Test coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover

# Compiled files
*.class
*.jar
*.exe

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Node (if using any JS tools)
node_modules/
package-lock.json
yarn.lock

# Database
*.db
*.sqlite
*.sqlite3
mongo-data/

# Temporary files
tmp/
temp/
*.tmp

# IDE specific files
.vscode/settings.json
.idea/json.net.iml
.project

# Demo/test files
demo/
test_output/
results/

# Secrets and credentials
secrets/
credentials/
api_keys/
private_keys/

# Large files (keep repo size manageable)
*.zip
*.tar.gz
*.7z
*.iso

# Documentation generated files
docs/_build/
site/

# Cache directories
.cache/
*/.cache/
